# Node 依赖（仅本地开发/测试需要）
compressor/node_modules/

# Vendored 库文件（由 GitHub Actions 从 node_modules 复制，不入库）
compressor/fengari-web.js
compressor/luaparse.js

# 构建产物（由 GitHub Actions 用 GenerateHtml.py 现场生成，不入库）
# 注意用 / 锚定到仓库根，避免误伤 compressor/index.html（压缩器页面需入库）
/index.html
/pages/

# 远程测试缓存（remotetest.js 首次联网拉取的外部 main.lua，仅本地复用）
compressor/tests/.remote-cache/

# 批量测试克隆的第三方仓库（bulktest.js 自动下载，仅本地使用）
compressor/tests/_bulk_test_repos/

# 压缩结果快照（snapshot.js 生成的重构安全网基线，仅本地用于回归比对）
compressor/tests/_snapshot.json
compressor/tests/_snapshot_baseline.json
